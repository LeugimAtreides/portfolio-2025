# Django core
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Supabase (local + deployed)
# Dashboard → Project Settings → Database → Connection string → URI.
# Use the direct host, port 5432, for migrate and admin. Example:
#   postgresql://postgres.[ref]:YOUR_PASSWORD@db.[ref].supabase.co:5432/postgres?sslmode=require
EXTERNAL_DATABASE_URL=

# Database — optional fallback: local Postgres only when EXTERNAL_DATABASE_URL is empty
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=your-db-password

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# CSRF — comma-separated; include scheme (production API + public site)
# CSRF_TRUSTED_ORIGINS=https://api.example.com,https://www.example.com

# CKEditor uploads — optional override (defaults: FileSystemStorage if DEBUG, else S3)
# CKEDITOR_5_FILE_STORAGE=django.core.files.storage.FileSystemStorage

# AWS S3 — only required in production (when DJANGO_DEBUG=False)
# Bucket: allow public GetObject via bucket policy (ACLs often disabled by default).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
